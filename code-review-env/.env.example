//Old config settings
# Server
GRAPHREVIEW_HOST=0.0.0.0
GRAPHREVIEW_PORT=8000
GRAPHREVIEW_OUTPUT_DIR=outputs

# Source and DB
GRAPHREVIEW_SOURCE_ROOT=sample_project
GRAPHREVIEW_DB_PATH=
GRAPHREVIEW_DATABASE_URL=
GRAPHREVIEW_DB_ECHO=false

# Optional remote SQLite (Turso/libSQL)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
GRAPHREVIEW_REMOTE_SQLITE_URL=
GRAPHREVIEW_REMOTE_SQLITE_AUTH_TOKEN=

# Runtime limits
GRAPHREVIEW_MAX_STEPS_PER_EPISODE=80
GRAPHREVIEW_MAX_FILES=5000
GRAPHREVIEW_SEED_WORKERS=4
GRAPHREVIEW_PROGRESS=true

# Agent/Judge models
GRAPHREVIEW_LLM_PROVIDER=ollama_openai_compat
GRAPHREVIEW_LLM_BASE_URL=http://localhost:11434/v1
GRAPHREVIEW_LLM_API_KEY=ollama
GRAPHREVIEW_LLM_MODEL_AGENT=gemma4:e4b
GRAPHREVIEW_LLM_MODEL_JUDGE=gemma4:e4b

# Hard grader - primary judge
GRAPHREVIEW_JUDGE_ENABLED=true
GRAPHREVIEW_JUDGE_PROVIDER=ollama_openai_compat
GRAPHREVIEW_JUDGE_MODEL=gemma4:e4b
GRAPHREVIEW_JUDGE_BASE_URL=http://localhost:11434/v1
GRAPHREVIEW_JUDGE_API_KEY=ollama
GRAPHREVIEW_JUDGE_TIMEOUT_SECONDS=8
GRAPHREVIEW_JUDGE_REASONING_EFFORT=none
GRAPHREVIEW_JUDGE_THINK=false
GRAPHREVIEW_JUDGE_MAX_CALLS=200
GRAPHREVIEW_JUDGE_MAX_CONSECUTIVE_FAILURES=3

# Hard grader - verifier model
GRAPHREVIEW_VERIFIER_ENABLED=true
GRAPHREVIEW_VERIFIER_PROVIDER=ollama_openai_compat
GRAPHREVIEW_VERIFIER_MODEL=gemma4:e4b
GRAPHREVIEW_VERIFIER_BASE_URL=http://localhost:11434/v1
GRAPHREVIEW_VERIFIER_API_KEY=ollama
GRAPHREVIEW_VERIFIER_TIMEOUT_SECONDS=8

# Adaptive fusion weights
GRAPHREVIEW_JUDGE_WEIGHT_DETERMINISTIC=0.5
GRAPHREVIEW_JUDGE_WEIGHT_PRIMARY=0.3
GRAPHREVIEW_JUDGE_WEIGHT_VERIFIER=0.2
GRAPHREVIEW_JUDGE_DISAGREEMENT_THRESHOLD=0.5

# Edge summaries
GRAPHREVIEW_EDGE_SUMMARY_ENABLED=true
GRAPHREVIEW_EDGE_SUMMARY_MODEL=gemma4:e4b
GRAPHREVIEW_EDGE_SUMMARY_BASE_URL=http://localhost:11434/v1
GRAPHREVIEW_EDGE_SUMMARY_API_KEY=ollama
GRAPHREVIEW_EDGE_SUMMARY_TIMEOUT_SECONDS=8
GRAPHREVIEW_EDGE_SUMMARY_MAX_CALLS=5000

# LoRA / continual learning hooks
GRAPHREVIEW_LORA_ENABLED=false
GRAPHREVIEW_LORA_DATA_PATH=outputs/lora/transitions.jsonl

# Hard autonomous issue finder (proposal + precision gating)
GRAPHREVIEW_HARD_ISSUE_FINDER_ENABLED=true
GRAPHREVIEW_HARD_ISSUE_FINDER_MODEL=gemma4:e4b
GRAPHREVIEW_HARD_ISSUE_FINDER_BASE_URL=http://localhost:11434/v1
GRAPHREVIEW_HARD_ISSUE_FINDER_API_KEY=ollama
GRAPHREVIEW_HARD_ISSUE_FINDER_TIMEOUT_SECONDS=12
GRAPHREVIEW_HARD_ISSUE_FINDER_MAX_ISSUES=4
GRAPHREVIEW_HARD_PROPOSAL_MIN_CONFIDENCE=0.70
